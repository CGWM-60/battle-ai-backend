APP_PORT=8080
APP_HOST=0.0.0.0
GIN_MODE=debug

JWT_SECRET=dev-secret-change-me
ADMIN_USERNAME=admin
# Avoid '#' in raw ADMIN_PASSWORD values when passing through dotenv-style tools.
# Prefer ADMIN_PASSWORD_BCRYPT in production.
ADMIN_PASSWORD=admin
ADMIN_PASSWORD_BCRYPT=
ADMIN_SESSION_SECRET=dev-admin-session-secret
ADMIN_API_SECRET=dev-admin-api-secret

AI_PROVIDER_TEST_TIMEOUT_SECONDS=20
AI_PROVIDER_GENERATION_TIMEOUT_SECONDS=45

APP_MAX_CONCURRENT_REQUESTS=8
APP_QUEUE_TIMEOUT_SECONDS=10
APP_MAX_BODY_BYTES=1048576

MARIADB_PORT=3306
PHPMYADMIN_PORT=8081
MARIADB_DATABASE=battleia
MARIADB_USER=battleia
MARIADB_PASSWORD=battleia
MARIADB_ROOT_PASSWORD=root

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=battleia
DB_USER=battleia
DB_PASSWORD=battleia
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

OPEN_AI_KEY=
OPEN_AI_MODEL=

MISTRAL_AI_KEY=
MISTRAL_AI_MODEL=

# Billing (AI wallet + store)
# mock = seed catalogue + achats simules | stripe = Stripe Checkout | disabled = pas de boutique
BILLING_MODE=mock
AI_PLATFORM_MODE=mock
AI_CREDITS_ENABLED=true
AI_MOCK_ENABLED=true
STORE_VERIFIER=mock
BILLING_CURRENCY=EUR
BILLING_LOW_BALANCE_THRESHOLD=50
BILLING_TOKENS_PER_NEXUS_COIN=1000
DEFAULT_FREE_DAILY_CREDITS=100
DEFAULT_STARTER_BONUS_CREDITS=500
# Legacy alias (optional)
BILLING_STARTER_BONUS_NEXUS_COINS=500
# Stripe (when BILLING_MODE=stripe)
BILLING_STRIPE_SECRET_KEY=
BILLING_STRIPE_WEBHOOK_SECRET=
BILLING_STRIPE_SUCCESS_URL=
BILLING_STRIPE_CANCEL_URL=
