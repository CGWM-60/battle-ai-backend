# ============================
# Dokploy environment variables
# ============================
# Copy/paste these keys into Dokploy > Environment Variables

# App
APP_HOST=0.0.0.0
APP_PORT=8080
GIN_MODE=release

# Security (REQUIRED)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_USERNAME=admin
# Generate with: htpasswd -bnBC 12 "" "your-password" | tr -d ':\n'
ADMIN_PASSWORD_BCRYPT=CHANGE_ME_BCRYPT_HASH
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_API_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# AI timeouts
AI_PROVIDER_TEST_TIMEOUT_SECONDS=20
AI_PROVIDER_GENERATION_TIMEOUT_SECONDS=45

# Request limits
APP_MAX_CONCURRENT_REQUESTS=8
APP_QUEUE_TIMEOUT_SECONDS=10
APP_MAX_BODY_BYTES=1048576

# Database (internal mariadb service)
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=battleia
DB_USER=battleia
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# DB pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
