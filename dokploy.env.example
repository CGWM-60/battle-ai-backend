# ============================
# Dokploy environment variables
# ============================
# Copy/paste these keys into Dokploy > Environment Variables

# App
APP_HOST=0.0.0.0
APP_PORT=8080
GIN_MODE=release

# Security (REQUIRED)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_USERNAME=admin
# Optional plaintext fallback for debugging only.
# Avoid '#' and surrounding quotes in raw env values because some dotenv/UIs may
# truncate or alter them. Prefer ADMIN_PASSWORD_BCRYPT in production.
# Example safe temporary value: Admin2026Secure
ADMIN_PASSWORD=
# Generate with: htpasswd -bnBC 12 "" "your-password" | tr -d ':\n'
ADMIN_PASSWORD_BCRYPT=CHANGE_ME_BCRYPT_HASH
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_API_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# AI timeouts
AI_PROVIDER_TEST_TIMEOUT_SECONDS=20
AI_PROVIDER_GENERATION_TIMEOUT_SECONDS=60
AI_QUEST_CRON_TIMEOUT_SECONDS=900
AI_QUEST_PROVIDER_CALL_TIMEOUT_SECONDS=60

# Request limits
APP_MAX_CONCURRENT_REQUESTS=8
APP_QUEUE_TIMEOUT_SECONDS=10
APP_MAX_BODY_BYTES=1048576

# Database (internal mariadb service)
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=battleia
DB_USER=battleia
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# DB pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30

# Redis (internal redis service in compose)
REDIS_URL=redis://redis:6379/0

# Persistent uploaded assets.
# In Dokploy, mount Persistent Storage on container path /nexus_game/assets.
NEXUS_ASSETS_BASE_DIR=/nexus_game/assets
NEXUS_ASSETS_BASE_URL=/nexus_game/assets
HERO_IMAGE_PUBLIC_DIR=/nexus_game/assets/heroes
HERO_IMAGE_PUBLIC_BASE_URL=/assets/heroes

# Billing (AI wallet + store)
BILLING_MODE=mock
AI_PLATFORM_MODE=mock
AI_CREDITS_ENABLED=true
AI_MOCK_ENABLED=true
STORE_VERIFIER=mock
BILLING_CURRENCY=EUR
BILLING_LOW_BALANCE_THRESHOLD=50
BILLING_TOKENS_PER_NEXUS_COIN=1000
DEFAULT_FREE_DAILY_CREDITS=100
DEFAULT_STARTER_BONUS_CREDITS=500
BILLING_STARTER_BONUS_NEXUS_COINS=500
BILLING_STRIPE_SECRET_KEY=
BILLING_STRIPE_WEBHOOK_SECRET=
BILLING_STRIPE_SUCCESS_URL=
BILLING_STRIPE_CANCEL_URL=
